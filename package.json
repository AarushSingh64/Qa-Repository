{
  "name": "qa-repository",
  "version": "1.0.0",
  "description": "Capital POS Playwright automation framework",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "playwright test",
    "test:login": "playwright test --project=login",
    "test:login:smoke": "playwright test playwright/tests/login/login.smoke.spec.ts --project=login",
    "test:login:regression": "playwright test playwright/tests/login/login.regression.spec.ts --project=login",
    "test:login:security": "playwright test playwright/tests/login/login.security.spec.ts --project=login",
    "test:login:lockout": "playwright test playwright/tests/login/login.lockout.spec.ts --project=login-lockout",
    "test:smoke": "playwright test --project=smoke",
    "test:onboarding": "playwright test playwright/tests/smoke/onboarding.spec.ts --project=smoke",
    "test:headed": "playwright test --headed",
    "test:live": "playwright test playwright/tests/login/login.smoke.spec.ts --project=login --headed --workers=1 && set AUTH_FORCE=true&& playwright test auth.setup.ts --project=setup --headed --workers=1 && playwright test tenant-create.spec.ts --project=authenticated --headed --workers=1 && playwright test onboarding.spec.ts --project=smoke --headed --workers=1",
    "test:auth": "set AUTH_FORCE=true&& playwright test auth.setup.ts --project=setup",
    "test:tenant": "playwright test tenant-create.spec.ts --project=authenticated",
    "test:turnstile-debug": "playwright test turnstile-debug.spec.ts --project=debug",
    "test:turnstile-diagnostic": "playwright test turnstile-diagnostic.spec.ts --project=debug",
    "report": "playwright show-report playwright-report"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/node": "^22.15.3",
    "dotenv": "^16.5.0",
    "typescript": "^5.8.3"
  }
}
