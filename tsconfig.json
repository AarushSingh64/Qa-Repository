{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@pages/*": ["playwright/pages/*"],
      "@utils/*": ["playwright/utils/*"],
      "@data/*": ["playwright/data/*"],
      "@fixtures/*": ["playwright/fixtures/*"],
      "@helpers/*": ["playwright/helpers/*"],
      "@assertions/*": ["playwright/assertions/*"],
      "@constants/*": ["playwright/constants/*"]
    }
  },
  "include": ["playwright.config.ts", "playwright/**/*.ts"]
}
