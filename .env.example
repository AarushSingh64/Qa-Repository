BASE_URL=https://stage.admin.supplyvalid.in

SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=

# Optional: only needed when reusing an existing tenant instead of fresh-tenant onboarding
TENANT_EMAIL=
TENANT_PASSWORD=

# Cloudflare Turnstile is disabled on staging — login is fully automated.
#
# Run commands:
#   npm test -- login.spec.ts          Login tests (fresh browser)
#   npm run test:auth                  Bootstrap Super Admin Chrome profile
#   npm run test:tenant                Tenant creation (authenticated profile)
#   npm run test:onboarding            Full serial onboarding smoke (headed: HEADED=true)
#   npm run test:smoke                 All smoke specs
#   npm run report                     Open HTML report
#
# Optional: AUTH_FORCE=true  (npm run test:auth sets this to refresh session)
