BASE_URL=https://stage.admin.supplyvalid.in

SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=

# Optional: only needed when reusing an existing tenant instead of fresh-tenant onboarding
TENANT_EMAIL=
TENANT_PASSWORD=

# Persistent Chrome profile authentication (launchPersistentContext)
#
# 1. npm run test:auth
#    - Launches Chrome with playwright/.profile/superadmin
#    - Pauses for manual captcha + login (one-time)
#    - Session persists automatically in the profile directory
#
# 2. npm run test:tenant
#    - Reuses the same Chrome profile — skips login completely
#
# Optional: AUTH_FORCE=true  (npm run test:auth sets this to re-login)
